{
  "name": "@zylem/examples",
  "private": true,
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "optimize:gltf": "node ./repo-actions/optimize-gltf-assets.mjs",
    "destructible-prebake": "zylem-destructible-prebake",
    "test:e2e": "playwright test",
    "screenshot": "node --experimental-strip-types --disable-warning=ExperimentalWarning ./repo-actions/screenshot.ts",
    "screenshot:local": "node --experimental-strip-types --disable-warning=ExperimentalWarning ./repo-actions/screenshot-local.ts"
  },
  "dependencies": {
    "@solidjs/router": "^0.14.10",
    "@zylem/assets": "^0.1.1",
    "@zylem/editor": "workspace:*",
    "@zylem/game-lib": "workspace:*",
    "@zylem/shaders": "workspace:*",
    "@zylem/ui": "^0.2.0",
    "howler": "^2.2.4",
    "nanoid": "^5.1.5",
    "solid-js": "^1.9.9",
    "spacetimedb": "2.1.0",
    "three": "^0.185.0",
    "valtio": "^2.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20.19.13",
    "@types/three": "^0.185.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@zylem/utilities": "workspace:*",
    "cross-env": "^10.1.0",
    "typescript": "6.0.3",
    "vite": "7.0.4",
    "vite-plugin-glsl": "^1.5.4",
    "vite-plugin-solid": "^2.11.8"
  }
