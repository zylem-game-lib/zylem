# Copy to `.env.production` for local production builds, or set the same variable
# in CI / Render (Static Site → Environment) for deployed builds.
# SpacetimeDB on Render listens on 127.0.0.1 inside the container; browsers must use the public service URL (https → wss). See packages/server/README.md § Render deploy.
VITE_STDB_URI=https://your-spacetimedb-service.onrender.com
