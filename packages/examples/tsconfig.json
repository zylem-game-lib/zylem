{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "types": ["node", "vite/client", "vite-plugin-glsl/ext"],
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@zylem/styles": ["../zylem-styles/src/index.ts"],
      "@zylem/game-lib/core": ["../game-lib/src/api/core.ts"],
      "@zylem/game-lib/entity": ["../game-lib/src/api/entity.ts"],
      "@zylem/game-lib/behavior": ["../game-lib/src/api/behavior.ts"],
      "@zylem/game-lib/audio": ["../game-lib/src/api/audio.ts"],
      "@zylem/game-lib/globals": ["../game-lib/src/api/globals.ts"],
      "@zylem/game-lib/actions": ["../game-lib/src/api/actions.ts"],
      "@zylem/game-lib/input": ["../game-lib/src/api/input.ts"],
      "@zylem/game-lib/input-ui": ["../game-lib/src/api/input-ui.ts"],
      "@zylem/game-lib/graphics": ["../game-lib/src/api/graphics.ts"],
      "@zylem/game-lib/events": ["../game-lib/src/api/events.ts"],
      "@zylem/game-lib/debug": ["../game-lib/src/api/debug.ts"],
      "@zylem/game-lib/web-components": ["../game-lib/src/api/web-components.ts"],
      "@zylem/game-lib/runtime": ["../game-lib/src/api/runtime.ts"],
      "~/*": ["../game-lib/src/*"],
      "@/*": ["../game-lib/src/*"],
      "@lib/debug/*": ["../editor/src/debug/*"],
      "@lib/ui/*": ["../editor/src/ui/*"],
      "@lib/*": ["../game-lib/src/lib/*"],
      "@interfaces/*": ["../game-lib/src/lib/interfaces/*"],
      "@state/*": ["../game-lib/src/state/*"]
    }
  },
  "include": ["src", "repo-actions", "*.html", "../editor/src", "../zylem-styles/src"],
  "references": [{ "path": "../game-lib" }]
}
