{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "composite": true,
    "noEmit": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@lib/debug/*": ["./src/lib/debug/*"],
      "@lib/ui/*": ["./src/lib/ui/*"],
      "@lib/*": ["./src/lib/*"],
      "@interfaces/*": ["./src/lib/interfaces/*"],
      "@state/*": ["./src/state/*"],
      "@zylem/game-lib/core": ["./src/api/core.ts"],
      "@zylem/game-lib/entity": ["./src/api/entity.ts"],
      "@zylem/game-lib/behavior": ["./src/api/behavior.ts"],
      "@zylem/game-lib/audio": ["./src/api/audio.ts"],
      "@zylem/game-lib/globals": ["./src/api/globals.ts"],
      "@zylem/game-lib/actions": ["./src/api/actions.ts"],
      "@zylem/game-lib/input": ["./src/api/input.ts"],
      "@zylem/game-lib/input-ui": ["./src/api/input-ui.ts"],
      "@zylem/game-lib/graphics": ["./src/api/graphics.ts"],
      "@zylem/game-lib/events": ["./src/api/events.ts"],
      "@zylem/game-lib/debug": ["./src/api/debug.ts"],
      "@zylem/game-lib/web-components": ["./src/api/web-components.ts"],
      "@zylem/game-lib/runtime": ["./src/api/runtime.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/lib/ui/**/*.tsx", "src/lib/debug/**/*.tsx", "src/lib/debug/**/console-store.ts", "src/lib/debug/state-based-debug-loader.ts", "tests", "**/*.spec.ts", "**/*.test.ts"]
}
