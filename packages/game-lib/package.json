{
  "name": "@zylem/game-lib",
  "version": "0.7.0",
  "type": "module",
  "description": "A powerful and easy-to-use framework for creating simple 3D digital interactive applications using TypeScript.",
  "license": "MIT",
  "author": "Tim Cool",
  "repository": {
    "type": "git",
    "url": "https://github.com/zylem-game-lib/zylem.git"
  },
  "contributors": [
    {
      "name": "Tim Cool",
      "email": "tcoolpg@gmail.com",
      "url": "https://github.com/tcool86"
    }
  ],
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./entity": {
      "types": "./dist/entity.d.ts",
      "import": "./dist/entity.js"
    },
    "./behavior": {
      "types": "./dist/behavior.d.ts",
      "import": "./dist/behavior.js"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.js"
    },
    "./globals": {
      "types": "./dist/globals.d.ts",
      "import": "./dist/globals.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js"
    },
    "./input-ui": {
      "types": "./dist/input-ui.d.ts",
      "import": "./dist/input-ui.js"
    },
    "./graphics": {
      "types": "./dist/graphics.d.ts",
      "import": "./dist/graphics.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./debug": {
      "types": "./dist/debug.d.ts",
      "import": "./dist/debug.js"
    },
    "./web-components": {
      "types": "./dist/web-components.d.ts",
      "import": "./dist/web-components.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "keywords": [
    "game",
    "three",
    "typescript",
    "rapier3d",
    "physics",
    "framework",
    "vite",
    "simple",
    "interactive"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --reporter=verbose",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "@dgreenheck/three-pinata": "^2.0.1",
    "@dimforge/rapier3d-compat": "^0.11.2",
    "@sinclair/typebox": "^0.34.41",
    "@zylem/behaviors": "^0.3.0",
    "@types/howler": "^2.2.12",
    "howler": "^2.2.4",
    "idb-keyval": "^6.2.2",
    "msgpackr": "^1.11.5",
    "nanoid": "^5.1.5",
    "stats.js": "^0.17.0",
    "three": "^0.184.0",
    "typescript-fsm": "^1.6.0",
    "valtio": "^2.1.7"
  },
  "peerDependencies": {
    "@dimforge/rapier3d-compat": "^0.11.2",
    "@zylem/runtime": "^0.1.0",
    "howler": "^2.2.4",
    "nanoid": "^5.1.5",
    "three": "^0.184.0",
    "valtio": "^2.1.7"
  },
  "peerDependenciesMeta": {
    "@zylem/runtime": {
      "optional": true
    }
  },
  "devDependencies": {
    "@zylem/runtime": "workspace:*",
    "@types/node": "^20.19.13",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.184.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^27.2.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "5.8.2",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.0.9"
  }
}
