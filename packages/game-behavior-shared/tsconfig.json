{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"baseUrl": "./",
		"composite": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"noEmit": true,
		"types": [],
		"noUncheckedIndexedAccess": false,
		"exactOptionalPropertyTypes": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
