{
  "name": "@zylem/behavior-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Runtime-agnostic foundation for Zylem behaviors: descriptor/system contracts, transform/velocity capability substrate, and shared utilities. No dependency on @zylem/game-lib.",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.32.1"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typescript-fsm": "^1.6.0",
    "valtio": "^2.1.7"
  },
  "peerDependencies": {
    "@dimforge/rapier3d-compat": "^0.11.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@dimforge/rapier3d-compat": "^0.11.2",
    "@types/node": "^20.19.13",
    "@types/three": "0.171.0",
    "three": "^0.180.0",
    "tsup": "^8.5.1",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@10.33.0"
}
