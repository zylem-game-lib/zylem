{
  "name": "zylem-monorepo",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Zylem game library monorepo - TypeScript 2025 Edition",
  "license": "MIT",
  "author": "Tim Cool",
  "repository": {
    "type": "git",
    "url": "https://github.com/zylem-game-lib/zylem.git"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "zylem": "node --experimental-strip-types ./scripts/zylem-runner.ts",
    "dev": "sh ./scripts/dev.sh",
    "dev:editor": "pnpm --filter @zylem/editor dev",
    "dev:examples": "pnpm --filter @zylem/examples dev",
    "dev:examples:screenshot": "node --experimental-strip-types ./packages/examples/repo-actions/screenshot-local.ts",
    "dev:server": "pnpm --filter @zylem/spacetime-server dev",
    "dev:shader-showcase": "pnpm --filter @zylem/shader-showcase dev",
    "build:shaders": "pnpm --filter @zylem/shaders build",
    "build:spacetime-server": "pnpm --filter @zylem/spacetime-server build",
    "start:spacetime-server": "pnpm --filter @zylem/spacetime-server start:server",
    "spacetime-server:build-and-start": "pnpm run build:spacetime-server && pnpm run start:spacetime-server",
    "dev:lib": "pnpm --filter @zylem/game-lib dev",
    "build:lib": "pnpm --filter @zylem/game-lib build",
    "build:editor": "pnpm --filter @zylem/editor build",
    "build:examples": "pnpm --filter @zylem/examples build",
    "build:render": "sh ./scripts/render-build.sh",
    "verify:render-docker": "bash ./scripts/verify-render-docker-image.sh",
    "build": "sh ./scripts/build.sh",
    "build:production": "cross-env NODE_ENV=production pnpm -r run build",
    "build:production:verify": "bash ./scripts/ci-production-verify.sh",
    "test": "sh ./scripts/test.sh",
    "test:e2e": "pnpm --filter @zylem/examples test:e2e",
    "coverage": "pnpm --filter @zylem/game-lib coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "install:all": "pnpm install",
    "publish": "sh ./scripts/publish.sh",
    "publish:lib": "sh ./scripts/publish.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@clack/prompts": "^1.6.0",
    "@solidjs/testing-library": "^0.8.10",
    "cross-env": "^10.1.0",
    "esbuild-plugin-solid": "^0.6.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vite": "7.0.4",
    "vite-plugin-glsl": "^1.5.4",
    "vite-plugin-solid": "^2.11.8"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@dgreenheck/three-pinata": "^2.0.1",
    "esbuild": "^0.27.2",
    "mitt": "^3.0.1",
    "multithreading": "^0.3.45"
  }
}
